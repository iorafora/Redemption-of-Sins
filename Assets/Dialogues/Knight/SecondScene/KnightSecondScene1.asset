  speakerName: "Anlat\u0131c\u0131"
  dialogueText: "*Soka\u011Fa ad\u0131m\u0131n\u0131 att\u0131\u011F\u0131nda kesik
    kesik nefes sesleri duydun. Y\u0131k\u0131lm\u0131\u015F bir duvar\u0131n yan\u0131nda
    bir muhaf\u0131z dizlerinin \xFCzerine \xE7\xF6km\xFC\u015Ft\xFC. Z\u0131rh\u0131
    par\xE7alanm\u0131\u015F, bedeni kan i\xE7indeydi. Titreyen elleriyle han\xE7erini
    kald\u0131rd\u0131 ve karn\u0131na saplad\u0131.*"
  choice1Text: "M\xFCdahale et"
  choice1NextNode: {fileID: 11400000, guid: 724216dfeb291ea44b4463f1888f6567, type: 2}
  choice2Text: "G\xF6rmezden gel"
