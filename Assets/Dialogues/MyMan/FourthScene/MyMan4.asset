  speakerName: "Anlat\u0131c\u0131"
  dialogueText: "*Z\u0131rhl\u0131 adam bir s\xFCre cevap vermedi. Elindeki bezle
    k\u0131l\u0131c\u0131n\u0131 temizlemeye devam ediyordu.*\n Ama sonra: \"Yedi
    Aziz Mirac\u0131na m\u0131 gidiyorsun?\""
  choice1Text: "\"Evet karde\u015Fim, sen de mi oraya gidiyorsun?\""
  choice1NextNode: {fileID: 11400000, guid: 20243552023f69f4dbdb28c133a53cb1, type: 2}
  choice2Text: "\"Yedi Aziz Mirac\u0131 m\u0131? Neden oraya gidiyorsun?\""
