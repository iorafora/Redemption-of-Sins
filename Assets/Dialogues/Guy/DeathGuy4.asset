  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  speakerName: Adam
  dialogueText: "\"Ah-... sen.\"\n\"\u015E\xFCk\xFCrler olsun, o yarat\u0131klardan
    birisi de\u011Filsin.\"\n\"Rahip... daha fazla ilerleme, ileride korkun\xE7 bir
    canavar var.\""
  choice1Text: "\"Ne canavar\u0131?\" \"Orada ne var?\""
  choice1NextNode: {fileID: 11400000, guid: be4dd38de869049478f58916604eb17d, type: 2}
  choice2Text: "Sessiz kal, adam\u0131n \xF6l\xFCm\xFCn\xFC izle"
